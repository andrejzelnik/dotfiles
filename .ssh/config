Include config.local

Host *
    # Keep connections alive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Security
    HashKnownHosts yes
    IdentitiesOnly yes

    # macOS keychain integration
    AddKeysToAgent yes
    UseKeychain yes

    # Reuse connections to the same host
    ControlMaster auto
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 10m
